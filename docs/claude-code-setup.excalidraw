    {
      "id": "zngmJ3siohftSPixVLk5E",
      "type": "text",
      "x": -623.5578642983866,
      "y": 733.2123582977632,
      "width": 537.8825073242188,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0FG",
      "roundness": null,
      "seed": 783822474,
      "version": 267,
      "versionNonce": 269292950,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775713791166,
      "link": null,
      "locked": false,
      "text": "Запускай и тестируй проект в Docker.\nИспользуй chrome devtools mcp для тестирования в браузере.\nИспользуй frontend-design-skill и impeccable skills для\nфронтенда и дизайна.\nДелай ревью дизайна с помощью impeccable skills, давай\nварианты выбора.\nКомментарии в коде должны быть на русском.\nОбщайся со мной на русском.",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
